  pmid = {28169594},
  annotation = {MAG ID: 2610293228\\
S2ID: 0fdb8deea2ac5ea0382c0d18e77942672b148fdf},
  file = {/run/user/1000/gvfs/google-drive:host=gmail.com,user=hudsonburke01/0AHhFn0AIpfB-Uk9PVA/1tXqkJoI1nMchW1xEqMNApoDXFn8jNn9l/VML/Juliana A. Passipieri et al. - 2017 - Keratin Hydrogel Enhances In Vivo Skeletal Muscle Function in a Rat Model of Volumetric Muscle Loss..pdf}
}

